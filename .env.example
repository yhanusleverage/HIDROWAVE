# Copiar para .env.local (dev) ou variáveis no Railway Dashboard (prod)
# Credenciais: Supabase Dashboard → API, ou copiar de ESP-HIDROWAVE-main/secrets.ini
#   supabase_url        → NEXT_PUBLIC_SUPABASE_URL
#   supabase_anon_key   → NEXT_PUBLIC_SUPABASE_ANON_KEY (JWT completo, não "eyJ...")

# Supabase — obrigatório
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# URL pública da app (API routes server→server). Railway preenche RAILWAY_PUBLIC_DOMAIN automaticamente;
# se preferir explícito: https://sua-app.up.railway.app
# NEXT_PUBLIC_BASE_URL=https://sua-app.up.railway.app

# Railway define PORT automaticamente — não precisa configurar manualmente

# Fase 3 — push MQTT comandos relé (opcional; sin esto ESP usa poll HTTPS ~60s)
# Ver docs/RAILWAY_MQTT_ENV.md
# MQTT_HOST=99.79.36.220
# MQTT_PORT=1883
# MQTT_PUBLISH_USER=hidrowave
# MQTT_PUBLISH_PASS=
